MODULE BomAutodeskViewer;

REQUIRE Bom, AutodeskViewer, ItemAutodeskViewer;

NAMESPACE Manufacturing;

bom = DATA Bom (Model);
nameBom 'Bill of Materials' (Model m) = description(bom(m));

EXTEND FORM autodesk
    PROPERTIES(m) nameBom
;

@defineAutodeskViewer(bom, details);

EXTEND FORM bom
    FILTERS bom(adm) = b OR item(adm) = item(b)
;
