MODULE ProjectAutodeskViewer;

REQUIRE Project, AutodeskViewer;

NAMESPACE ProjectManagement;

project = DATA Project (Model);
nameProject 'Project' (Model m) = name(project(m));

EXTEND FORM autodesk
    PROPERTIES(m) nameProject
;

@defineAutodeskViewer(project);

EXTEND FORM project
    FILTERS project(adm) = p
;
