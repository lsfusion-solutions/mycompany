MODULE ScrapJournalEntryInitial;

REQUIRE ScrapJournalEntry, GLAccountInitial, ScrapInitial, Journal;

NAMESPACE Inventory;

loadDefaultData () + {
    journal(ScrapType t) <- journal(r'miscellaneous') WHERE t IS ScrapType;
    costAmountDebitAccount(ScrapType t) <- GLAccount('5900') WHERE t IS ScrapType;
    costAmountCreditAccount(ScrapType t) <- GLAccount('1200') WHERE t IS ScrapType;
}
