MODULE ManufacturingOrderScrapCost;

REQUIRE ManufacturingOrderScrap, ManufacturingOrderCost, ScrapCost;

NAMESPACE Manufacturing;

cost (ManufacturingOrder o, ManufacturingCostType t) += WHEN t = ManufacturingCostType.extra THEN GROUP SUM amount(ScrapCostLedger l) IF manufacturingOrder(scrap(line(l))) = o;