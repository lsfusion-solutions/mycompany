MODULE OpenAI;

REQUIRE Utils, Authentication, MasterData, FileUtils;

NAMESPACE OpenAI;

customUrl r'Url' = DATA STRING () CHARWIDTH 50;
apiKey r'API key' = DATA STRING () CHARWIDTH 60;

apiUrl() = r'https://api.openai.com/v1/responses';

baseApiUrl() = replace(apiUrl(), r'/responses', '');
fileContentUrl (STRING fileId) = baseApiUrl() + r'/files/' + fileId + r'/content';
containerFileContentUrl (STRING containerId, STRING fileId) = baseApiUrl() + r'/containers/' + containerId + r'/files/' + fileId + r'/content';

headers (STRING header) = CASE
    WHEN header = r'Authorization' THEN r'Bearer ' + apiKey()
;

EXTEND FORM integrationData
    PROPERTIES() openAIApiKey = apiKey
;

DESIGN integrationData {
    pane {
        NEW openAI {
            caption = r'OpenAI';
            NEW openAIHeader {
                lines = 2;
                alignment = STRETCH;
                MOVE PROPERTY(openAIApiKey);
            }
        }
    }
}

// configuration
CLASS GPTConfiguration 'GPT configuration';

name '{Name}' = DATA ISTRING[50] (GPTConfiguration) IN id;
model 'Model' = DATA STRING (GPTConfiguration) CHARWIDTH 20;
reasoning 'Reasoning' = DATA STRING (GPTConfiguration) CHARWIDTH 10;
additionalPrompt 'Additional prompt' = DATA TEXT (GPTConfiguration);

FORM GPTConfiguration 'GPT configuration'
    OBJECTS c = GPTConfiguration PANEL
    PROPERTIES(c) name, model, reasoning, additionalPrompt

    EDIT GPTConfiguration OBJECT c
;

DESIGN GPTConfiguration {
    OBJECTS {
        NEW header {
            horizontal = TRUE;
            alignment = STRETCH;
            MOVE PROPERTY(name(c));
            MOVE PROPERTY(model(c));
            MOVE PROPERTY(reasoning(c));
        }
        NEW prompt {
            caption = 'Additional prompt';
            fill = 1;
            MOVE PROPERTY(additionalPrompt(c)) {
                caption = '';
                fill = 1;
            }
        }
    }
}

FORM dialogGPTConfigurations 'GPT configurations'
    OBJECTS c = GPTConfiguration
    PROPERTIES(c) READONLY name, model, reasoning

    LIST GPTConfiguration OBJECT c
;

countConfiguration 'Configurations' () = GROUP SUM 1 IF c IS GPTConfiguration;
defaultConfiguration 'Configuration' () = GROUP LAST GPTConfiguration c ORDER DESC c WHERE c IS GPTConfiguration IF countConfiguration() = 1;

// request
CLASS GPTRequest 'GPT request';

configuration 'Configuration' = DATA GPTConfiguration (GPTRequest);
nameConfiguration 'Configuration' (GPTRequest r) = name(configuration(r));
configuration(GPTRequest r) <- defaultConfiguration() WHEN SET(r IS GPTRequest);
    
model 'Model' = DATA STRING (GPTRequest) CHARWIDTH 20;
reasoning 'Reasoning' = DATA STRING (GPTRequest) CHARWIDTH 10;
imageGeneration 'Image generation' = DATA BOOLEAN (GPTRequest);
prompt 'Prompt' = DATA TEXT (GPTRequest);
additionalPrompt 'Additional prompt' = DATA TEXT (GPTRequest);

response 'Response' = DATA TEXT (GPTRequest);

status 'Status' = DATA STRING (GPTRequest) CHARWIDTH 15;
requestId 'Response ID' = DATA STRING (GPTRequest) CHARWIDTH 30;
sentDateTime 'Sent at' = DATA DATETIME (GPTRequest);
inputTokens 'Input tokens' = DATA INTEGER (GPTRequest);
outputTokens 'Output tokens' = DATA INTEGER (GPTRequest);
totalTokens 'Total tokens' = DATA INTEGER (GPTRequest);
errorMessage 'Error' = DATA TEXT (GPTRequest);

requestBody 'Request' = DATA FILE (GPTRequest);
responseBody 'Response' = DATA FILE (GPTRequest);
openResponseBody 'Response' (GPTRequest r) { open(responseBody(r)); }

effectiveModel 'Model' (GPTRequest r) = OVERRIDE model(r), model(configuration(r)), r'gpt-5';
effectiveReasoning 'Reasoning' (GPTRequest r) = OVERRIDE reasoning(r), reasoning(configuration(r));
effectiveAdditionalPrompt 'Additional prompt' (GPTRequest r) = OVERRIDE additionalPrompt(r), additionalPrompt(configuration(r));
effectivePrompt 'Prompt' (GPTRequest r) = CONCAT '\n\n', prompt(r), effectiveAdditionalPrompt(r);

// input file
CLASS GPTInputFile 'Input file';

request 'Request' = DATA GPTRequest (GPTInputFile) INDEXED NONULL DELETE;

file = DATA NAMEDFILE (GPTInputFile);

name '{Name}' (GPTInputFile f) = ISTRING(name(file(f)));
extension 'Extension' (GPTInputFile f) = ISTRING(extension(file(f)));

open 'Open' (GPTInputFile f) { open(file(f)); } IMAGE 'open.png';

index '{Index}' (GPTInputFile f) = PARTITION SUM 1 ORDER f BY request(f) MATERIALIZED CHARWIDTH 3;

newInputFile 'File' (GPTRequest r) {
    INPUT uf = NAMEDFILE DO NEW uof = GPTInputFile {
        request(uof) <- r;
        file(uof) <- uf;
    }
} IMAGE 'add.png' CHANGEKEY 'INSERT' HIDE;

// output
CLASS GPTOutputFile 'Output file';

request 'Request' = DATA GPTRequest (GPTOutputFile) INDEXED NONULL DELETE;

file = DATA RAWFILE (GPTOutputFile);

name '{Name}' = DATA ISTRING (GPTOutputFile) CHARWIDTH 15;

open 'Open' (GPTOutputFile f) { open(file(f), name(f)); } IMAGE 'open.png';

countInputFiles 'Input files' (GPTRequest r) = GROUP SUM 1 IF request(GPTInputFile f) = r;
countOutputFiles 'Output files' (GPTRequest r) = GROUP SUM 1 IF request(GPTOutputFile f) = r;

// request
inputRequestFile (GPTRequest r, INTEGER i) = GROUP MIN GPTInputFile f IF request(f) = r AND index(f) = i;

isImage (GPTInputFile f) = isImage(extension(f));
mimeType (GPTInputFile f) = mimeType(extension(f));
dataUrl (GPTInputFile f) = r'data:' + mimeType(f) + r';base64,' + encodeBase64Unchunked(file(f));

includeContent (GPTRequest r, INTEGER i) = i = 0 OR inputRequestFile(r, i);

contentType (GPTRequest r, INTEGER i) = CASE
    WHEN i = 0 THEN r'input_text'
    WHEN isImage(inputRequestFile(r, i)) THEN r'input_image'
    ELSE r'input_file'
;

contentFilename (GPTRequest r, INTEGER i) = name(inputRequestFile(r, i)) IF i != 0 AND NOT isImage(inputRequestFile(r, i));
contentFileData (GPTRequest r, INTEGER i) = dataUrl(inputRequestFile(r, i)) IF i != 0 AND NOT isImage(inputRequestFile(r, i));
contentImageUrl (GPTRequest r, INTEGER i) = dataUrl(inputRequestFile(r, i)) IF i != 0 AND isImage(inputRequestFile(r, i));

contentJSON (GPTRequest r) = JSON FROM type = contentType(r, INTEGER i) IF includeContent(r, i),
                                                   text = effectivePrompt(r) IF i = 0,
                                                   filename = name(inputRequestFile(r, i)) IF NOT isImage(inputRequestFile(r, i)),
                                                   file_data = dataUrl(inputRequestFile(r, i)) IF NOT isImage(inputRequestFile(r, i)),
                                                   image_url = dataUrl(inputRequestFile(r, i)) IF isImage(inputRequestFile(r, i));

inputJSON (GPTRequest r) = JSON FROM role = r'user' IF INTEGER i = 0, 
                                                 content = contentJSON(r) IF i = 0;

reasoningJSON (GPTRequest r) = JSON FROM effort = effectiveReasoning(r);

toolType (GPTRequest r, INTEGER i) = CASE
    WHEN i = 1 THEN r'code_interpreter'
    WHEN i = 2 AND imageGeneration(r) THEN r'image_generation'
;
toolContainer() = JSON FROM type = r'auto';

toolsJSON (GPTRequest r) = JSON FROM type = toolType(r, INTEGER i),
                                                 container = (JSON FROM type = r'auto') IF i = 1;

requestJSON (GPTRequest r) = JSON FROM model = effectiveModel(r),
                                              reasoning = reasoningJSON(r) IF effectiveReasoning(r),
                                              input = inputJSON(r),
                                              tools = toolsJSON(r),
                                              instructions = r'If you create output files, use the code interpreter tool and cite each created file in the response text.',
                                              store = TFALSE;
showRequestJSON 'Request' (GPTRequest r) { MESSAGE requestJSON(r);  }

importAnnotations (GPTRequest r, JSON annotations) {
    IMPORT JSON FROM annotations FIELDS STRING type = type,
                                        STRING fileId = file_id,
                                        STRING containerId = container_id,
                                        STRING fileName = filename DO {
        IF fileId AND (containerId OR type = r'file_path') THEN {
            LOCAL downloadFile = FILE();

            EXTERNAL HTTP GET IF containerId THEN containerFileContentUrl(containerId, fileId) ELSE fileContentUrl(fileId)
                          HEADERS headers TO downloadFile;

            IF downloadFile() THEN
                NEW of = GPTOutputFile {
                    name(of) <- OVERRIDE fileName, r'output_' + STRING((countOutputFiles(r)) (+) 1);
                    request(of) <- r;
                    file(of) <- RAWFILE(downloadFile());
                }
        }
    }
}

importContent (GPTRequest r, JSON itemContent) {
    IMPORT JSON FROM itemContent FIELDS STRING contentType = type, TEXT contentText = text, TEXT refusalText = refusal, TEXT annotations = annotations DO {
        IF contentType = r'output_text' THEN {
            IF contentText THEN
                response(r) <- CONCAT '\n', response(r), contentText;
            IF annotations THEN
                importAnnotations(r, JSON FROM annotations);
        }
        IF contentType = r'refusal' AND refusalText THEN
            response(r) <- CONCAT '\n', response(r), refusalText;
    }
}

request (GPTRequest r) {
    IF NOT apiKey() OR trim(apiKey()) = '' THEN {
        MESSAGE 'Specify OpenAI API key';
        RETURN;
    }
    
    model(r) <- effectiveModel(r);
    reasoning(r) <- effectiveReasoning(r);
    additionalPrompt(r) <- effectiveAdditionalPrompt(r);
    sentDateTime(r) <- currentDateTime();

    LOCAL apiResponse = FILE();

    TRY {
        timeoutHttp() <- 3600000;
        EXTERNAL HTTP POST apiUrl() HEADERS headers PARAMS requestJSON(r) TO apiResponse;

        responseBody(r) <- apiResponse();

        LOCAL responseId = STRING();
        LOCAL responseStatus = STRING();
        LOCAL output = JSON();
        LOCAL responseError = JSON();
        LOCAL incompleteDetails = JSON();
        LOCAL usage = JSON();

        IMPORT JSON FROM apiResponse() TO() responseId = id,
                responseStatus = status,
                output,
                responseError = error,
                incompleteDetails = incomplete_details,
                usage;

        IF usage() THEN
            IMPORT JSON FROM usage() FIELDS() INTEGER input_tokens,
            INTEGER output_tokens,
            INTEGER total_tokens DO {
                inputTokens(r) <- input_tokens;
                outputTokens(r) <- output_tokens;
                totalTokens(r) <- total_tokens;
            }

        requestId(r) <- responseId();
        status(r) <- responseStatus();

        IF responseError() THEN
            errorMessage(r) <- fieldText(responseError(), r'message');
        IF NOT errorMessage(r) AND incompleteDetails() THEN
            errorMessage(r) <- fieldText(incompleteDetails(), r'reason');

        IF output() THEN
            IMPORT JSON FROM output() FIELDS STRING itemType = type, TEXT itemContent = content, TEXT imageResult = result, TEXT revisedPrompt = revised_prompt DO {
                IF itemType = r'message' AND itemContent THEN {
                    importContent(r, JSON FROM itemContent);
                }
                IF itemType = r'image_generation_call' AND imageResult THEN
                    NEW of = GPTOutputFile {
                        name(of) <- r'image_' + STRING((countOutputFiles(r)) (+) 1) + '.png';
                        request(of) <- r;
                        file(of) <- decode(imageResult, r'base64');
                    }
            };

    } CATCH {
        IF apiResponse() THEN
            responseBody(r) <- apiResponse();
        status(r) <- 'Failed';
        errorMessage(r) <- (OVERRIDE (CONCAT '\n', messageCaughtException(), resultString()), 'OpenAI request failed');
    }
}


send 'Send' (GPTRequest r) {
    APPLY;
    IF canceled() THEN RETURN;

    NEWSESSION {
        request(r);
        APPLY;
    }
}

FORM GPTRequest 'GPT Request'
    OBJECTS r = GPTRequest PANEL
    PROPERTIES(r) nameConfiguration
    PROPERTIES(r) model, reasoning, imageGeneration
    PROPERTIES(r) send
    PROPERTIES(r) prompt
    PROPERTIES(r) READONLY response, status, requestId, sentDateTime, 
                           inputTokens, outputTokens, totalTokens, errorMessage
    PROPERTIES(r) showRequestJSON, openResponseBody SHOWIF responseBody(r)

    OBJECTS fi = GPTInputFile
    PROPERTIES(fi) READONLY index
    PROPERTIES(fi) name, extension
    PROPERTIES(fi) GRID open, DELETE
    FILTERS request(fi) = r

    PROPERTIES(r) newInputFile DRAW fi TOOLBAR

    OBJECTS fo = GPTOutputFile
    PROPERTIES(fo) READONLY name
    PROPERTIES(fo) GRID open
    FILTERS request(fo) = r

    EDIT GPTRequest OBJECT r
;

DESIGN GPTRequest {
    OBJECTS {
        NEW actions {
            horizontal = TRUE;
            alignment = STRETCH;
            MOVE PROPERTY(send(r));
        }
        NEW body {
            horizontal = TRUE;
            fill = 1;
            NEW leftPane {
                fill = 3;
                NEW header {
                    lines = 3;
                    alignment = STRETCH;
                    MOVE PROPERTY(nameConfiguration(r));
                    MOVE PROPERTY(model(r));
                    MOVE PROPERTY(reasoning(r));
                    MOVE PROPERTY(imageGeneration(r));
                    MOVE PROPERTY(status(r));
                    MOVE PROPERTY(requestId(r));
                    MOVE PROPERTY(sentDateTime(r));
                }
                NEW prompt {
                    caption = 'Prompt';
                    fill = 1;
                    MOVE PROPERTY(prompt(r)) {
                        fill = 1;
                        caption = '';
                    }
                }
                NEW response {
                    caption = 'Response';
                    fill = 1;
                    MOVE PROPERTY(response(r)) {
                        fill = 1;
                        caption = '';
                        height = -1;
                    }
                }
            }
            NEW rightPane {
                fill = 1;
                NEW inputFiles {
                    caption = 'Input files';
                    fill = 1;
                    MOVE BOX(fi) { caption = ''; GRID(fi) { height = 100; } }
                }
                NEW outputFiles {
                    caption = 'Output files';
                    fill = 1;
                    MOVE BOX(fo) { caption = ''; GRID(fo) { height = 100; } }
                }
                NEW debug {
                    caption = 'Debug';
                    fill = 1;
                    NEW debugRequestResponse {
                        horizontal = TRUE;
                        alignment = STRETCH;
                        MOVE PROPERTY(showRequestJSON(r)) { fill = 1; }
                        MOVE PROPERTY(openResponseBody(r)) { fill = 1; }
                    }
                    NEW tokens {
                        horizontal = TRUE;
                        alignment = STRETCH;
                        MOVE PROPERTY(inputTokens(r));
                        MOVE PROPERTY(outputTokens(r));
                        MOVE PROPERTY(totalTokens(r));
                    }
                    MOVE PROPERTY(errorMessage(r)) { captionVertical = TRUE; size = (-1, -1); }
                }
            }
        }
    }
}

EXTEND FORM integrationData
    OBJECTS oaic = GPTConfiguration
    PROPERTIES(oaic) READONLY name, model, reasoning
    PROPERTIES(oaic) NEWSESSION NEW, EDIT, DELETE

    OBJECTS oair = GPTRequest
    PROPERTIES(oair) READONLY nameConfiguration, model, reasoning, imageGeneration, sentDateTime, status, requestId, inputTokens, outputTokens, totalTokens,
                              countInputFiles, countOutputFiles
    PROPERTIES(oair) NEWSESSION NEW, EDIT, DELETE
;

DESIGN integrationData {
    openAI {
        MOVE BOX(oaic);
        MOVE BOX(oair) { fill = 3; }
    }
}

// actions
GPTRequest = DATA LOCAL NESTED GPTRequest();

requestGPT (TEXT prompt, NAMEDFILE file1, NAMEDFILE file2, NAMEDFILE file3) {
    NEWSESSION {
        NEW r = GPTRequest {
            prompt(r) <- prompt;
            IF file1 THEN {
                NEW f = GPTInputFile {
                    request(f) <- r;
                    file(f) <- file1;
                }
            }
            IF file2 THEN {
                NEW f = GPTInputFile {
                    request(f) <- r;
                    file(f) <- file2;
                }
            }
            IF file3 THEN {
                NEW f = GPTInputFile {
                    request(f) <- r;
                    file(f) <- file3;
                }
            }
            
            IF countConfiguration() > 1 THEN {
                DIALOG dialogGPTConfigurations OBJECTS c INPUT DO {
                    configuration(r) <- c;
                } ELSE RETURN;
            }

            request(r);
            APPLY;
            
            GPTRequest() <- r;
        }
    }
}
requestGPT (TEXT prompt, NAMEDFILE file1, NAMEDFILE file2) { requestGPT(prompt, file1, file2, NULL); }
requestGPT (TEXT prompt, NAMEDFILE file1) { requestGPT(prompt, file1, NULL, NULL); }

