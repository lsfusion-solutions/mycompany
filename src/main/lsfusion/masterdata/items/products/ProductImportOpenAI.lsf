MODULE ProductImportOpenAI;

REQUIRE ProductImport, CategoryImport, OpenAI, FileUtils;

NAMESPACE MasterData;

importOpenAIPrompt 'Prompt' = DATA TEXT();

fillDefaultImportOpenAIPrompt 'Default' () {
    importOpenAIPrompt() <-
    r'Extract only new product categories and products from the attached file and return only a valid JSON object.
      No markdown, no code fences, no explanations.
      Use this schema: {"categories":[{"name":"...","parent":"EXISTING_PARENT_ID_OR_NEW_PARENT_NAME"}],"products":[{"name":"...","category":"EXISTING_CATEGORY_ID_OR_NEW_CATEGORY_NAME","reference":"...","uom":"UOM_ID"}]}.
      Return only categories and products that do not already exist in the attached reference JSON file.
      Do not return id fields for categories or products. Their ids are generated by the system.
      For products that belong to newly created categories, use exactly the same category name as in the categories array.
      For a new category parent, return the existing parent category id if it already exists in the reference JSON.
      If the parent category is also new and is returned in the categories array, return that new parent category name instead of an id.
      Do not create new UoMs. Always return an existing UoM id from the reference JSON, or return null / omit the field if none fit.
      If a product reference number is absent, use null or omit the field.';
}

EXTEND FORM options
    PROPERTIES() fillDefaultImportOpenAIPrompt,
        importOpenAIPrompt
;

DESIGN options {
    items {
        NEW productImportOpenAI {
            fill = 1;
            caption = 'Import (GPT)';
            MOVE PROPERTY(fillDefaultImportOpenAIPrompt());
            MOVE PROPERTY(importOpenAIPrompt()) {
                captionVertical = TRUE;
                fill = 1;
            }
        }
    }
}

importCategoryName = DATA LOCAL ISTRING[50] (INTEGER);
importCategoryParent = DATA LOCAL ISTRING[50] (INTEGER);

importProductName = DATA LOCAL ISTRING[200] (INTEGER);
importProductCategory = DATA LOCAL ISTRING[200] (INTEGER);
importProductReference = DATA LOCAL STRING[50] (INTEGER);
importProductUom = DATA LOCAL ISTRING[50] (INTEGER);

FORM importOpenAIJson
    OBJECTS categories = INTEGER
    PROPERTIES(categories) importCategoryName EXTID 'name',
                           importCategoryParent EXTID 'parent'

    OBJECTS products = INTEGER
    PROPERTIES(products) importProductName EXTID 'name',
                         importProductCategory EXTID 'category',
                         importProductReference EXTID 'reference',
                         importProductUom EXTID 'uom'
;

FORM importOpenAIPreview 'Import'
    OBJECTS c = Category
    PROPERTIES(c) name, id, canonicalNameParent, DELETE
    FILTERS NOT PREV(c IS Category)
    ORDERS name(c)

    OBJECTS p = Product
    PROPERTIES(p) dataName, id, reference, nameUom, canonicalNameCategory, DELETE
    FILTERS NOT PREV(p IS Product)
    ORDERS dataName(p)
;

DESIGN importOpenAIPreview {
    size = (1100, 650);
    OBJECTS {
        NEW pane {
            horizontal = TRUE;
            fill = 1;
            MOVE BOX(c) {
                fill = 1;
                caption = 'Categories';
            }
            MOVE BOX(p) {
                fill = 2;
                caption = 'Products';
            }
        }
    }
}

newCategoryByName (ISTRING[200] category) = GROUP MIN Category c IF NOT PREV(c IS Category) AND name(c) = category; 

previewImportProductOpenAI (JSON json) {
    IMPORT importOpenAIJson JSON FROM json;

    FOR [GROUP SUM 1 BY importCategoryName(INTEGER categoryRow)](ISTRING[50] categoryName) DO NEW c = Category {
        name(c) <- categoryName;
    }

    FOR importCategoryName(INTEGER categoryRow) AND name(Category c) = importCategoryName(categoryRow) AND NOT PREV(c IS Category) DO
        parent(c) <- OVERRIDE
            category(importCategoryParent(categoryRow)),
            newCategoryByName(importCategoryParent(categoryRow)),
            rootCategory();

    FOR importProductName(INTEGER productRow) DO
        NEW p = Product {
            dataName(p) <- importProductName(productRow);

            category(p) <- OVERRIDE
                category(importProductCategory(productRow)),
                newCategoryByName(importProductCategory(productRow)),
                rootCategory();

            reference(p) <- importProductReference(productRow);
            uom(p) <- uom(importProductUom(productRow));
        }

    DIALOG importOpenAIPreview DOCKED MANAGESESSION;
}

importOpenAI 'Import (GPT)' (Category root) {
    INPUT f = NAMEDFILE DO {
        NEWSESSION {
            EXPORT JSON FROM
                items = (JSON FROM
                    id(Item i),
                    name = dataName(i),
                    reference(i),
                    category = idCategory(i),
                    uom = idUom(i)
                    WHERE id(i) AND level(category(i), root)),
                categories = (JSON FROM
                    id(Category c),
                    name(c),
                    idParent(c)
                    WHERE id(c) AND level(c, root)),
                uoms = (JSON FROM
                    id(Uom u),
                    name(u)
                    WHERE id(u));

            requestGPT(importOpenAIPrompt(), f,
                namedFile(exportFile(), r'import-reference-data'));

            IF NOT GPTRequest() THEN
                RETURN;

            IF errorMessage(GPTRequest()) THEN {
                MESSAGE errorMessage(GPTRequest());
                RETURN;
            }

            previewImportProductOpenAI(JSON FROM response(GPTRequest()));
        }
    }
} WAIT;

EXTEND FORM items
    PROPERTIES(c) importOpenAI SHOWIF importOpenAIPrompt() TOOLBAR
;
