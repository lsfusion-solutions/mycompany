MODULE EmployeePrintInitial;

REQUIRE EmployeePrintType, DefaultData;

NAMESPACE MasterData;

loadDefaultData () + {
    NEW tm = PrintEmployeeType {
        name(tm) <- 'Badge' + r' 3x2';
        template(tm) <- r'EmployeeBadgeA4_3x2.jrxml';
    }
    NEW tm = PrintEmployeeType {
        name(tm) <- 'Badge' + r' 2x5';
        template(tm) <- r'EmployeeBadgeA4_2x5.jrxml';
    }
}
